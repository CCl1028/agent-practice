# === 模型配置 ===
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.deepseek.com  # 如用 OpenAI 官方可删除此行

# 视觉模型配置（截图识别用，需要支持图片输入的多模态模型）
# DeepSeek 不支持图片，推荐使用 SiliconFlow（https://siliconflow.cn 免费注册）
VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
VISION_API_KEY=sk-xxx                            # SiliconFlow 的 API Key
VISION_BASE_URL=https://api.siliconflow.cn/v1    # SiliconFlow API 地址
# 也可以用 OpenAI: VISION_MODEL=gpt-4o-mini / VISION_BASE_URL=https://api.openai.com/v1

# === 新闻搜索配置（v2 新增，配置任一即可，大幅提升分析质量） ===

# Tavily — 推荐首选，免费 1000 次/月
# 注册地址：https://tavily.com/
TAVILY_API_KEY=tvly-xxx

# 博查搜索 — 中文搜索优化，支持 AI 摘要
# 注册地址：https://open.bocha.cn/
BOCHA_API_KEY=

# Brave Search — 隐私优先，海外基金/美股优化
# 注册地址：https://brave.com/search/api/
BRAVE_API_KEY=

# SerpAPI — Google 搜索 API，兜底
# 注册地址：https://serpapi.com/
SERPAPI_API_KEY=

# === 推送配置（可选，至少配一个即可收到推送） ===

# Bark — 推送到 iPhone 通知栏（最简单，推荐）
# App Store 下载 Bark，打开 App 复制推送 URL
BARK_URL=https://api.day.app/你的key

# Server酱 — 推送到微信
# 注册地址：https://sct.ftqq.com，微信扫码后获取 SendKey
SERVERCHAN_KEY=

# 企业微信 Webhook — 推送到企业微信群
# 在企业微信群 → 添加群机器人 → 复制 Webhook URL
WECOM_WEBHOOK_URL=
